rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Get user profile to determine role
    function getRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }
    
    // Is the user an admin?
    function isAdmin() {
      return request.auth != null && getRole(request.auth.uid) == 'admin';
    }
    
    // Is the user an authenticated user (either via password or anonymous)?
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // User Profiles: Only admins can manage user roles. Users can read their own profile.
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Patients: Can be created by any authenticated user. Read by admins.
    match /patients/{patientId} {
      allow create: if isAuthenticated();
      allow read, update: if isAdmin();
    }

    // Appointments: 
    // - Anyone authenticated (including anonymous) can create.
    // - Admins can read, update, and delete all appointments.
    match /appointments/{appointmentId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }
    
    // Clinics, Colonias, Settings: Publicly readable, but only writable by an admin.
    match /clinics/{clinicId} {
       allow read: if true;
       allow write: if isAdmin();
    }
    
    match /colonias/{coloniaId} {
       allow read: if true;
       allow write: if isAdmin();
    }

    match /settings/{docId} {
       allow read: if true;
       allow write: if isAdmin();
    }
    
    // Reports: Writable and readable by admins. Access for clinic staff is handled by password check in backend.
    match /reports/{reportId} {
        allow read, write: if isAdmin();
    }
  }
}
