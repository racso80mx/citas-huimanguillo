rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Appointments can be created by anyone, and are publicly readable.
    // Deletes are restricted to authenticated users (admins).
    match /appointments/{appointmentId} {
      allow read, create: if true;
      allow delete: if request.auth != null; // Simplified: Should be admin-only
    }

    // Settings are publicly readable, but only writable by an admin.
    match /settings/{docId} {
       allow read: if true;
       allow write: if request.auth != null; // Simplified: Should be admin-only
    }
  }
}
