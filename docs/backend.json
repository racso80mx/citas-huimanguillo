
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents an authenticated admin user.",
      "properties": {
        "id": { "type": "string", "description": "Firebase Authentication UID." },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "doctor"] }
      },
      "required": ["id", "email", "name", "role"]
    },
    "Patient": {
      "title": "Patient",
      "type": "object",
      "description": "Represents a patient in the system.",
      "properties": {
        "expediente": {
          "type": "string",
          "description": "Patient's file number."
        },
        "name": {
          "type": "string"
        },
        "paternalLastName": {
          "type": "string"
        },
        "maternalLastName": {
          "type": "string"
        },
        "birthDate": {
          "type": "string",
          "format": "date",
          "description": "Patient's date of birth (FNacimiento)."
        },
        "age": {
          "type": "number"
        },
        "sex": {
          "type": "string",
          "enum": [
            "Hombre",
            "Mujer"
          ]
        },
        "birthState": {
          "type": "string",
          "description": "State of birth."
        },
        "address": {
          "type": "string",
          "description": "Patient's home address (Domicilio)."
        },
        "coloniaName": {
          "type": "string"
        },
        "fatherName": {
          "type": "string",
          "description": "Patient's father's name (NombrePadr)."
        },
        "motherName": {
          "type": "string",
          "description": "Patient's mother's name (NombreMad)."
        },
        "fatherAge": {
          "type": "number",
          "description": "Patient's father's age (EdadPadre)."
        },
        "motherAge": {
          "type": "number",
          "description": "Patient's mother's age (EdadMadre)."
        },
        "registrationDate": {
          "type": "string",
          "format": "date",
          "description": "Date the patient record was created (FechaApertu)."
        },
        "status": {
          "type": "string",
          "description": "Patient's current status.",
          "enum": ["Vigente", "Baja", "Baja Definitiva"]
        },
        "derechoAbiencia": {
          "type": "string",
          "description": "Patient's insurance provider (e.g., IMSS, ISSSTE)."
        },
        "phoneNumber": {
          "type": "string"
        },
        "curp": {
          "type": "string"
        },
        "lastAppointmentDate": {
          "type": "string",
          "format": "date",
          "description": "Date of the patient's last appointment."
        }
      },
      "required": [
        "curp",
        "name",
        "paternalLastName",
        "maternalLastName",
        "phoneNumber"
      ]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "Represents a scheduled appointment.",
      "properties": {
        "appointmentNumber": { "type": "string" },
        "patientId": { "type": "string" },
        "clinicId": { "type": "string" },
        "coloniaName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "time": { "type": "string" },
        "patientType": { "type": "string", "enum": ["General", "Crónico", "Embarazada", "3ra Edad"] },
        "status": { "type": "string", "enum": ["Agendada", "Atendido", "No Atendido", "No Asistió"] }
      },
      "required": ["appointmentNumber", "patientId", "clinicId", "date", "time", "patientType", "status"]
    },
    "LabAppointment": {
      "title": "Lab Appointment",
      "type": "object",
      "description": "Represents a scheduled laboratory appointment.",
      "properties": {
        "appointmentNumber": { "type": "string" },
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "time": { "type": "string" },
        "studies": { 
          "type": "array", 
          "items": { "type": "object" }
        },
        "status": { "type": "string", "enum": ["Agendada", "Atendido", "No Atendido", "No Asistió"] }
      },
      "required": ["appointmentNumber", "patientId", "date", "time", "studies", "status"]
    },
     "LabStudy": {
      "title": "Lab Study",
      "type": "object",
      "description": "Represents a single laboratory study.",
      "properties": {
        "section": { "type": "string" },
        "name": { "type": "string" },
        "sampleType": { "type": "string" },
        "fastingHours": { "type": "string" },
        "available": { "type": "boolean" }
      },
      "required": ["section", "name", "sampleType", "fastingHours", "available"]
    },
    "XRayAppointment": {
        "title": "X-Ray Appointment",
        "type": "object",
        "description": "Represents a scheduled X-Ray appointment.",
        "properties": {
            "appointmentNumber": { "type": "string" },
            "patientId": { "type": "string" },
            "date": { "type": "string", "format": "date-time" },
            "time": { "type": "string" },
            "studyId": { "type": "string" },
            "status": { "type": "string", "enum": ["Agendada", "Atendido", "No Atendido", "No Asistió"] }
        },
        "required": ["appointmentNumber", "patientId", "date", "time", "studyId", "status"]
    },
    "XRayStudy": {
        "title": "X-Ray Study",
        "type": "object",
        "description": "Represents a single X-Ray study.",
        "properties": {
            "name": { "type": "string" },
            "indications": { "type": "string" },
            "available": { "type": "boolean" }
        },
        "required": ["name", "indications", "available"]
    },
    "UltrasoundAppointment": {
        "title": "Ultrasound Appointment",
        "type": "object",
        "description": "Represents a scheduled Ultrasound appointment.",
        "properties": {
            "appointmentNumber": { "type": "string" },
            "patientId": { "type": "string" },
            "date": { "type": "string", "format": "date-time" },
            "time": { "type": "string" },
            "studyId": { "type": "string" },
            "status": { "type": "string", "enum": ["Agendada", "Atendido", "No Atendido", "No Asistió"] }
        },
        "required": ["appointmentNumber", "patientId", "date", "time", "studyId", "status"]
    },
    "UltrasoundStudy": {
        "title": "Ultrasound Study",
        "type": "object",
        "description": "Represents a single Ultrasound study.",
        "properties": {
            "name": { "type": "string" },
            "indications": { "type": "string" },
            "available": { "type": "boolean" }
        },
        "required": ["name", "indications", "available"]
    },
    "Vaccine": {
        "title": "Vaccine",
        "type": "object",
        "description": "Represents a single vaccine.",
        "properties": {
            "name": { "type": "string" },
            "applicationAge": { "type": "string" },
            "sex": { "type": "string" },
            "description": { "type": "string" },
            "available": { "type": "boolean" }
        },
        "required": ["name", "applicationAge", "sex", "description", "available"]
    },
    "VaccineAppointment": {
      "title": "Vaccine Appointment",
      "type": "object",
      "description": "Represents a scheduled vaccination appointment.",
      "properties": {
        "appointmentNumber": { "type": "string" },
        "patientId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "time": { "type": "string" },
        "isNewborn": { "type": "boolean" },
        "clinicId": { "type": "string" },
        "vaccines": {
          "type": "array",
          "items": { "type": "object" }
        },
        "status": { "type": "string", "enum": ["Agendada", "Atendido", "No Atendido", "No Asistió"] }
      },
      "required": ["appointmentNumber", "patientId", "date", "time", "isNewborn", "vaccines", "status"]
    },
    "Clinic": {
        "title": "Clinic",
        "type": "object",
        "description": "Represents a clinic (Núcleo Básico).",
        "properties": {
            "name": { "type": "string" },
            "doctorName": { "type": "string" },
            "password": { "type": "string" },
            "dailySlots": { "type": "number" },
            "startTime": { "type": "string" },
            "endTime": { "type": "string" },
            "weekendBookingEnabled": { "type": "boolean" },
            "clinicType": { "type": "string", "enum": ["Consulta Externa", "Consulta Externa Especializada", "Psicología", "Nutrición", "Odontología"] },
            "bookingMode": { "type": "string", "enum": ["time", "token"] },
            "consultationDuration": { "type": "number" }
        },
        "required": ["name", "doctorName", "password", "dailySlots", "startTime", "endTime", "clinicType", "bookingMode"]
    },
    "Colonia": {
        "title": "Colonia",
        "type": "object",
        "description": "Represents a neighborhood and its assigned clinic.",
        "properties": {
            "name": { "type": "string" },
            "clinicId": { "type": "string" }
        },
        "required": ["name", "clinicId"]
    },
    "ActivityLog": {
        "title": "Activity Log",
        "type": "object",
        "description": "A single entry in the system's activity log.",
        "properties": {
          "timestamp": {"type": "string", "format": "date-time"},
          "action": {"type": "string"},
          "details": {"type": "string"}
        },
        "required": ["timestamp", "action", "details"]
    }
  }
}
