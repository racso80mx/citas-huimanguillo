{
  "entities": {
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Represents a scheduled appointment.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the appointment." },
        "date": { "type": "string", "description": "The date of the appointment in ISO format." },
        "consultorio": { "type": "number", "description": "The clinic ID number." },
        "curp": { "type": "string", "description": "The patient's CURP." },
        "nombre": { "type": "string", "description": "Patient's first name." },
        "apellidoPaterno": { "type": "string", "description": "Patient's paternal last name." },
        "apellidoMaterno": { "type": "string", "description": "Patient's maternal last name." },
        "sexo": { "type": "string", "enum": ["Hombre", "Mujer"] },
        "edad": { "type": "number" },
        "estadoNacimiento": { "type": "string" },
        "municipio": { "type": "string" },
        "colonia": { "type": "string" },
        "telefono": { "type": "string" }
      },
      "required": ["id", "date", "consultorio", "curp", "nombre", "apellidoPaterno", "apellidoMaterno", "sexo", "edad", "estadoNacimiento", "municipio", "colonia", "telefono"]
    },
    "Announcement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Announcement",
      "type": "object",
      "description": "A single announcement message.",
      "properties": {
        "messages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "A list of announcement strings."
        }
      },
      "required": ["messages"]
    },
    "SlotsConfig": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "SlotsConfig",
        "type": "object",
        "description": "Configuration for daily appointment slots per clinic.",
        "properties": {
            "config": {
                "type": "object",
                "additionalProperties": { "type": "number" },
                "description": "A map of consultorio ID to the number of slots."
            }
        },
        "required": ["config"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": { "$ref": "#/entities/Appointment" },
          "description": "Stores all appointment data. Publicly writable for booking, but admin-only for reads/deletes."
        }
      },
      {
        "path": "/settings/announcements",
        "definition": {
          "entityName": "Announcement",
          "schema": { "$ref": "#/entities/Announcement" },
          "description": "Stores a list of important announcements. Publicly readable, admin-only for writes."
        }
      },
      {
        "path": "/settings/slots",
        "definition": {
            "entityName": "SlotsConfig",
            "schema": { "$ref": "#/entities/SlotsConfig" },
            "description": "Stores the configuration for appointment slots. Publicly readable, admin-only for writes."
        }
      }
    ]
  }
}
