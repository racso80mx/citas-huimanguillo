
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents an authenticated admin user.",
      "properties": {
        "id": { "type": "string", "description": "Firebase Authentication UID." },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "doctor"] }
      },
      "required": ["id", "email", "name", "role"]
    },
    "Patient": {
      "title": "Patient",
      "type": "object",
      "description": "Represents a patient in the system.",
      "properties": {
        "expediente": {
          "type": "string",
          "description": "Patient's file number."
        },
        "name": {
          "type": "string"
        },
        "paternalLastName": {
          "type": "string"
        },
        "maternalLastName": {
          "type": "string"
        },
        "birthDate": {
          "type": "string",
          "format": "date",
          "description": "Patient's date of birth (FNacimiento)."
        },
        "age": {
          "type": "number"
        },
        "sex": {
          "type": "string",
          "enum": [
            "Hombre",
            "Mujer"
          ]
        },
        "birthState": {
          "type": "string",
          "description": "State of birth."
        },
        "address": {
          "type": "string",
          "description": "Patient's home address (Domicilio)."
        },
        "coloniaName": {
          "type": "string"
        },
        "fatherName": {
          "type": "string",
          "description": "Patient's father's name (NombrePadr)."
        },
        "motherName": {
          "type": "string",
          "description": "Patient's mother's name (NombreMad)."
        },
        "fatherAge": {
          "type": "number",
          "description": "Patient's father's age (EdadPadre)."
        },
        "motherAge": {
          "type": "number",
          "description": "Patient's mother's age (EdadMadre)."
        },
        "registrationDate": {
          "type": "string",
          "format": "date",
          "description": "Date the patient record was created (FechaApertu)."
        },
        "status": {
          "type": "string",
          "description": "Patient's current status.",
          "enum": ["Vigente", "Baja", "Baja Definitiva"]
        },
        "derechoAbiencia": {
          "type": "string",
          "description": "Patient's insurance provider (e.g., IMSS, ISSSTE)."
        },
        "phoneNumber": {
          "type": "string"
        },
        "curp": {
          "type": "string"
        },
        "lastAppointmentDate": {
          "type": "string",
          "format": "date",
          "description": "Date of the patient's last appointment."
        }
      },
      "required": [
        "curp",
        "name",
        "paternalLastName",
        "maternalLastName",
        "phoneNumber"
      ]
    }
  },
  "storage": {
    "description": "Almacenamiento de logotipos institucionales y recursos multimedia.",
    "rules": "allow read; allow write: if request.auth != null;"
  }
}
