{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents an authenticated user with a specific role.",
      "properties": {
        "id": { "type": "string", "description": "Firebase Authentication UID." },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "doctor"] },
        "clinicId": { "type": "string", "description": "ID of the clinic the doctor is assigned to. Only for 'doctor' role." }
      },
      "required": ["id", "email", "name", "role"]
    },
    "Patient": {
      "title": "Patient",
      "type": "object",
      "description": "Represents a patient in the system.",
      "properties": {
        "id": { "type": "string" },
        "curp": { "type": "string" },
        "name": { "type": "string" },
        "paternalLastName": { "type": "string" },
        "maternalLastName": { "type": "string" },
        "sex": { "type": "string", "enum": ["Hombre", "Mujer"] },
        "age": { "type": "number" },
        "birthState": { "type": "string" }
      },
      "required": ["id", "curp", "name", "paternalLastName", "maternalLastName"]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "Represents a scheduled appointment.",
      "properties": {
        "id": { "type": "string" },
        "appointmentNumber": { "type": "string" },
        "patientId": { "type": "string" },
        "clinicId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "time": { "type": "string" },
        "patientType": { "type": "string", "enum": ["General", "Crónico", "Embarazada", "3ra Edad"] },
        "status": { "type": "string", "enum": ["Pendiente", "Atendida", "Cancelada"] }
      },
      "required": ["id", "appointmentNumber", "patientId", "clinicId", "date", "time", "patientType", "status"]
    },
    "Clinic": {
        "title": "Clinic",
        "type": "object",
        "description": "Represents a clinic (Núcleo Básico).",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "doctorName": { "type": "string" },
            "dailySlots": { "type": "number" },
            "startTime": { "type": "string" },
            "endTime": { "type": "string" },
            "weekendBookingEnabled": { "type": "boolean" }
        },
        "required": ["id", "name", "doctorName", "dailySlots", "startTime", "endTime"]
    },
    "Colonia": {
        "title": "Colonia",
        "type": "object",
        "description": "Represents a neighborhood and its assigned clinic.",
        "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "clinicId": { "type": "string" }
        },
        "required": ["id", "name", "clinicId"]
    },
    "Announcement": {
      "title": "Announcement",
      "type": "object",
      "description": "A single announcement message.",
      "properties": {
        "messages": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["messages"]
    },
    "Report": {
        "title": "Report",
        "type": "object",
        "description": "Daily summary report for a clinic.",
        "properties": {
            "id": { "type": "string" },
            "clinicId": { "type": "string" },
            "date": { "type": "string", "format": "date" },
            "totalAppointments": { "type": "number" },
            "attended": { "type": "number" },
            "pending": { "type": "number" },
            "cancelled": { "type": "number" }
        },
        "required": ["id", "clinicId", "date", "totalAppointments"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/entities/User" }
        }
      },
      {
        "path": "/patients/{patientId}",
        "definition": {
          "entityName": "Patient",
          "schema": { "$ref": "#/entities/Patient" }
        }
      },
      {
        "path": "/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": { "$ref": "#/entities/Appointment" }
        }
      },
      {
        "path": "/clinics/{clinicId}",
        "definition": {
            "entityName": "Clinic",
            "schema": { "$ref": "#/entities/Clinic" }
        }
      },
      {
        "path": "/colonias/{coloniaId}",
        "definition": {
          "entityName": "Colonia",
          "schema": { "$ref": "#/entities/Colonia" }
        }
      },
      {
        "path": "/reports/{reportId}",
        "definition": {
          "entityName": "Report",
          "schema": { "$ref": "#/entities/Report" }
        }
      },
      {
        "path": "/settings/announcements",
        "definition": {
          "entityName": "Announcement",
          "schema": { "$ref": "#/entities/Announcement" }
        }
      }
    ]
  }
}
