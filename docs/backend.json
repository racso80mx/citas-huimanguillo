{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents an authenticated admin user.",
      "properties": {
        "id": { "type": "string", "description": "Firebase Authentication UID." },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "doctor"] }
      },
      "required": ["id", "email", "name", "role"]
    },
    "Patient": {
      "title": "Patient",
      "type": "object",
      "description": "Represents a patient in the system.",
      "properties": {
        "expediente": { "type": "string" },
        "name": { "type": "string" },
        "paternalLastName": { "type": "string" },
        "maternalLastName": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "age": { "type": "number" },
        "sex": { "type": "string", "enum": ["Hombre", "Mujer"] },
        "birthState": { "type": "string" },
        "address": { "type": "string" },
        "coloniaName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "curp": { "type": "string" },
        "status": { "type": "string", "enum": ["Vigente", "Baja", "Baja Definitiva"] }
      },
      "required": ["curp", "name", "paternalLastName", "maternalLastName", "phoneNumber"]
    }
  },
  "storage": {
    "description": "Almacenamiento de logotipos institucionales y recursos multimedia.",
    "rules": "allow read: if true; allow write: if request.auth != null;"
  }
}
