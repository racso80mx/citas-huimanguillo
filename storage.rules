
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Reglas para la carpeta de logotipos
    match /logos/{allPaths=**} {
      // Permitir que cualquiera pueda ver el logo (necesario para las recetas)
      allow read: if true;
      // Solo administradores autenticados pueden subir o cambiar el logo
      allow write: if request.auth != null;
    }
    
    // Regla por defecto para el resto de archivos
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
