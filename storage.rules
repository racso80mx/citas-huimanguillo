rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Permitir lectura pública para que jspdf pueda descargar el logo
      allow read: if true;
      // Solo usuarios autenticados pueden subir o borrar archivos
      allow write: if request.auth != null;
    }
  }
}