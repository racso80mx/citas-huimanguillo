rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Permitir lectura pública para que el logo sea accesible en las recetas
    match /{allPaths=**} {
      allow read: if true;
      // Solo usuarios autenticados pueden subir o modificar archivos
      allow write: if request.auth != null;
    }
  }
}